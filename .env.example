# =============================================================================
# Kita — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
CONTACT_EMAIL=hello@kitarun.com

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Running Club <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Strava Integration (optional)
# -----------------------------------------------------------------------------
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
STRAVA_STATE_SECRET=your-state-secret

# -----------------------------------------------------------------------------
# Push Notifications (optional — Web Push / VAPID)
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@kitarun.com

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret
